# DeepPredict Web - 环境变量配置
# 复制为 .env 后填入真实值

# ====== Stripe（必需）======
# 从 https://dashboard.stripe.com/apikeys 获取
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe Price IDs（从 Stripe Dashboard 创建产品后获取）
STRIPE_PRICE_100=price_xxxxx
STRIPE_PRICE_500=price_xxxxx
STRIPE_PRICE_1000=price_xxxxx

# ====== 数据库（可选，默认 SQLite）======
DATABASE_URL=sqlite:///./deeppredict.db

# ====== 服务（可选）======
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
